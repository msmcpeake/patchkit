# Copy to oidc.env (chmod 600) and fill in to enable OpenID Connect login.
# All five of ISSUER/CLIENT_ID/CLIENT_SECRET/REDIRECT_URI must be set for OIDC
# to activate; leave the file absent to keep OIDC disabled.
PATCHKIT_OIDC_ISSUER=https://your-idp.example.com/application/o/patchkit/
PATCHKIT_OIDC_CLIENT_ID=your-client-id
PATCHKIT_OIDC_CLIENT_SECRET=your-client-secret
PATCHKIT_OIDC_REDIRECT_URI=https://patchkit.example.com/auth/callback
# Optional: only members of this IdP group may log in (needs a groups claim).
PATCHKIT_OIDC_REQUIRED_GROUP=PatchKit Admins
# Optional: OAuth scopes (default: openid email profile) and session lifetime.
#PATCHKIT_OIDC_SCOPES=openid email profile
PATCHKIT_SESSION_TTL_HOURS=12
